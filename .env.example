# ── MySQL ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=lontarasign_mvp
MYSQL_USER=lontara_user
MYSQL_PASSWORD=change_me_db

# ── Backend DB connection ───────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=lontarasign_mvp
DB_USER=lontara_user
DB_PASSWORD=change_me_db

# ── App ────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_BASE_URL=https://your-domain.com
SECRET_KEY=generate_with__python_-c__import_secrets_print_secrets.token_urlsafe_64__

# ── CORS — comma-separated origins ─────────────────────
ALLOWED_ORIGINS=https://your-domain.com

# ── AI Review ─────────────────────────────────────────
AI_PROVIDER=openrouter
AI_API_KEY=sk-or-v1-your_openrouter_key_here
